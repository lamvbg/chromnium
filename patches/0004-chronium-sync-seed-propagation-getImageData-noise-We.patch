       SkIRect bounds =
           snapshot->PaintImageForCurrentFrame().GetSkImageInfo().bounds();
       DCHECK(!bounds.intersect(SkIRect::MakeXYWH(sx, sy, sw, sh)));
+    } else if (FingerprintState::IsActive() &&
+               image_data_pixmap.info().bytesPerPixel() == 4 &&
+               image_data_pixmap.writable_addr() != nullptr) {
+      // Chronium: per-profile seeded noise on the returned pixel buffer.
+      // Uses canvas-space coordinates (sx+x, sy+y) and the same "canvas"
+      // channel as toDataURL/toBlob so the same pixel is flipped
+      // consistently across all readback paths within a profile.
+      uint8_t* const base =
+          static_cast<uint8_t*>(image_data_pixmap.writable_addr());
+      const size_t row_bytes = image_data_pixmap.rowBytes();
+      const int width = image_data_pixmap.width();
+      const int height = image_data_pixmap.height();
+      for (int y = 0; y < height; ++y) {
+        uint8_t* row = base + static_cast<size_t>(y) * row_bytes;
+        for (int x = 0; x < width; ++x) {
+          const uint32_t hash = FingerprintState::HashAt(
+              "canvas", static_cast<uint32_t>(sx + x),
+              static_cast<uint32_t>(sy + y));
+          if ((hash & 0xFFu) == 0u) {
+            const uint32_t which = (hash >> 8) % 3u;
+            row[static_cast<size_t>(x) * 4u + which] ^= 1u;
+          }
+        }
+      }
     }
   }
 
