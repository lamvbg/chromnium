+  // Chronium: pin js_heap_size_limit to the profile-supplied value AFTER
+  // any QuantizeMemorySize bucketing has been applied inside the cache.
+  // Real V8 returns ~3.76 GB-bucketed on this device, leaking the actual
+  // heap configuration; ShardX-style profiles want a clean 4 GB value.
+  // We do this here instead of in GetHeapSize() so the override is the
+  // last word, surviving the cache's quantization step.
+  if (const auto* m = FingerprintState::Memory(); m) {
+    info_.js_heap_size_limit = static_cast<size_t>(m->heap_size_limit);
+  }
   // The values must have been computed, so totalJSHeapSize must be greater than
   // 0.
   DCHECK_GT(totalJSHeapSize(), 0u);
