     if (!fonts.empty()) {
       blink::FingerprintState::SetFontsAllowlist(fonts);
     }
+    const std::string memory_bytes =
+        cmd_line->GetSwitchValueASCII(switches::kFingerprintMemory);
+    if (!memory_bytes.empty()) {
+      uint64_t bytes = 0;
+      if (base::StringToUint64(memory_bytes, &bytes) && bytes > 0) {
+        blink::FingerprintState::MemoryFp m;
+        m.heap_size_limit = bytes;
+        blink::FingerprintState::SetMemory(m);
+      }
+    }
+    const std::string conn_csv =
+        cmd_line->GetSwitchValueASCII(switches::kFingerprintConnection);
+    if (!conn_csv.empty()) {
+      std::vector<std::string> parts = base::SplitString(
+          conn_csv, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_ALL);
+      if (parts.size() == 4) {
+        blink::FingerprintState::ConnectionFp c;
+        int rtt = 0;
+        int save = 0;
+        if (base::StringToDouble(parts[1], &c.downlink_mbps) &&
+            base::StringToInt(parts[2], &rtt) &&
+            base::StringToInt(parts[3], &save) && !parts[0].empty()) {
+          c.effective_type = parts[0];
+          c.rtt_msec = static_cast<uint32_t>(rtt);
+          c.save_data = (save != 0);
+          blink::FingerprintState::SetConnection(c);
+        }
+      }
+    }
+    const std::string quota_bytes =
+        cmd_line->GetSwitchValueASCII(switches::kFingerprintStorageQuota);
+    if (!quota_bytes.empty()) {
+      uint64_t bytes = 0;
+      if (base::StringToUint64(quota_bytes, &bytes) && bytes > 0) {
+        blink::FingerprintState::StorageFp s;
+        s.quota_bytes = bytes;
+        blink::FingerprintState::SetStorage(s);
+      }
+    }
+    const std::string webgl_limits =
+        cmd_line->GetSwitchValueASCII(switches::kFingerprintWebGLLimits);
+    if (!webgl_limits.empty()) {
+      std::vector<std::string> parts = base::SplitString(
+          webgl_limits, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_ALL);
+      if (parts.size() == 2) {
+        blink::FingerprintState::WebGLLimitsFp w;
+        if (base::StringToInt(parts[0], &w.max_texture_size) &&
+            base::StringToInt(parts[1], &w.max_vertex_attribs)) {
+          blink::FingerprintState::SetWebGLLimits(w);
+        }
+      }
+    }
+    const std::string voices_hex =
+        cmd_line->GetSwitchValueASCII(switches::kFingerprintSpeechVoices);
+    if (!voices_hex.empty()) {
+      std::vector<uint8_t> voices_bytes;
+      if (base::HexStringToBytes(voices_hex, &voices_bytes) &&
