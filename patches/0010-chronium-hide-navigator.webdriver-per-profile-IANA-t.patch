+++ b/third_party/blink/renderer/core/timezone/timezone_controller.cc
@@ -11,8 +11,10 @@
 #include "third_party/blink/public/platform/platform.h"
 #include "third_party/blink/public/platform/task_type.h"
 #include "third_party/blink/public/web/web_local_frame.h"
+#include "base/command_line.h"
 #include "third_party/blink/renderer/core/dom/events/event.h"
 #include "third_party/blink/renderer/core/frame/frame.h"
+#include "third_party/blink/renderer/platform/fingerprint/fingerprint_state.h"
 #include "third_party/blink/renderer/core/frame/local_dom_window.h"
 #include "third_party/blink/renderer/core/frame/local_frame.h"
 #include "third_party/blink/renderer/core/page/page.h"
@@ -109,6 +111,32 @@ void TimeZoneController::Init() {
   Platform::Current()->GetBrowserInterfaceBroker()->GetInterface(
       monitor.BindNewPipeAndPassReceiver());
   monitor->AddClient(instance().receiver_.BindNewPipeAndPassRemote());
+
+  // Chronium: install per-profile timezone via the same RAII handle DevTools
+  // emulation uses. We must read the switch directly from the command line
+  // because Init() runs from CoreInitializer (called by InitializeWebKit in
+  // RenderThreadImpl) BEFORE ChromeContentRendererClient::RenderThreadStarted
+  // has had a chance to populate blink::FingerprintState. The command line
+  // itself is set at process spawn, so it's available here.
+  static constexpr char kFingerprintTimezoneSwitch[] = "fingerprint-timezone";
+  const base::CommandLine* cmd_line = base::CommandLine::ForCurrentProcess();
+  if (cmd_line && cmd_line->HasSwitch(kFingerprintTimezoneSwitch)) {
+    const std::string tz =
+        cmd_line->GetSwitchValueASCII(kFingerprintTimezoneSwitch);
+    if (!tz.empty()) {
+      auto result = SetTimeZoneOverride(String(tz));
+      if (result.status == TimeZoneOverrideStatus::kSuccess && result.handle) {
+        // Intentional leak: the override should persist for the renderer's
+        // lifetime, and the handle has trivial state (RAII clears override
+        // on destruction, which we explicitly do NOT want here).
+        [[maybe_unused]] auto* leaked = result.handle.release();
+      }
+      // Make sure FingerprintState reflects what we installed; other patches
+      // may consume it via the typed accessor (e.g. for matching
+      // navigator.timeZone reads added later).
+      FingerprintState::SetTimezone(tz);
+    }
+  }
 }
 
 // static
diff --git a/third_party/blink/renderer/platform/fingerprint/fingerprint_state.cc b/third_party/blink/renderer/platform/fingerprint/fingerprint_state.cc
index 90edcf8e1c7f4..8dd88ce1ee309 100644
--- a/third_party/blink/renderer/platform/fingerprint/fingerprint_state.cc
+++ b/third_party/blink/renderer/platform/fingerprint/fingerprint_state.cc
@@ -45,6 +45,12 @@ std::string& AcceptLanguageStorage() {
 }
 std::atomic<bool> g_accept_language_set{false};
 
+std::string& TimezoneStorage() {
+  static base::NoDestructor<std::string> s;
+  return *s;
+}
+std::atomic<bool> g_timezone_set{false};
+
 FingerprintState::ScreenFp& ScreenStorage() {
   // POD with trivial destructor — base::NoDestructor would static-assert.
   static FingerprintState::ScreenFp s;
@@ -179,6 +185,23 @@ std::string_view FingerprintState::AcceptLanguage() {
   return AcceptLanguageStorage();
 }
 
+// static
+void FingerprintState::SetTimezone(std::string_view value) {
+  if (g_timezone_set.load(std::memory_order_acquire) || value.empty()) {
+    return;
+  }
+  TimezoneStorage().assign(value);
+  g_timezone_set.store(true, std::memory_order_release);
+}
+
+// static
+std::string_view FingerprintState::Timezone() {
+  if (!g_timezone_set.load(std::memory_order_acquire)) {
+    return {};
+  }
+  return TimezoneStorage();
+}
+
 // static
 void FingerprintState::SetScreen(const ScreenFp& screen) {
   if (g_screen_set.load(std::memory_order_acquire) || screen.width <= 0 ||
