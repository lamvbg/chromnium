+++ b/third_party/blink/renderer/core/frame/navigator.cc
@@ -104,6 +104,12 @@ bool Navigator::cookieEnabled() const {
 }
 
 bool Navigator::webdriver() const {
+  // Chronium: always false. Plan §5 #18 "CDP hide webdriver". Real Chrome
+  // user sessions return false; fingerprinters use any true value as a
+  // hard automation signal regardless of UA / fingerprint coherence.
+  if (FingerprintState::IsActive()) {
+    return false;
+  }
   if (RuntimeEnabledFeatures::AutomationControlledEnabled())
     return true;
 
