+std::string FingerprintProfile::FontsCsv() const {
+  if (!loaded_) {
+    return {};
+  }
+  const base::ListValue* list = dict_.FindList("fonts");
+  if (!list || list->empty()) {
+    return {};
+  }
+  std::string out;
+  for (const auto& item : *list) {
+    if (const std::string* s = item.GetIfString()) {
+      if (!out.empty()) out += ",";
+      out += *s;
+    }
+  }
+  return out;
+}
