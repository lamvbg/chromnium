diff --git a/chrome/browser/chrome_browser_main.cc b/chrome/browser/chrome_browser_main.cc
index 09c4540b4336f..62d0efc258821 100644
--- a/chrome/browser/chrome_browser_main.cc
+++ b/chrome/browser/chrome_browser_main.cc
@@ -40,6 +40,8 @@
 #include "chrome/browser/enterprise/chrome_browser_main_extra_parts_enterprise.h"
 #include "chrome/browser/fingerprint/fingerprint_profile.h"
 #include "chrome/browser/first_run/bookmark_importer.h"
+// IWYU pragma: keep — embedder_support/switches.h provides kUserAgent.
+#include "components/embedder_support/switches.h"
 #include "chrome/browser/first_run/first_run_features.h"
 #include "chrome/browser/gpu/chrome_browser_main_extra_parts_gpu.h"
 #include "chrome/browser/language/url_language_histogram_factory.h"
@@ -1210,11 +1212,23 @@ int ChromeBrowserMainParts::PreCreateThreadsImpl() {
   // singletons see it. Missing/malformed file is non-fatal — patches fall
   // back to default behavior when FingerprintProfile::IsLoaded() is false.
   {
-    const base::CommandLine* cmd_line =
-        base::CommandLine::ForCurrentProcess();
+    base::CommandLine* cmd_line = base::CommandLine::ForCurrentProcess();
     if (cmd_line->HasSwitch(switches::kFingerprintProfile)) {
-      chronium::FingerprintProfile::GetInstance()->LoadFromFile(
+      auto* fp = chronium::FingerprintProfile::GetInstance();
+      fp->LoadFromFile(
           cmd_line->GetSwitchValuePath(switches::kFingerprintProfile));
+      // Promote the JSON user_agent into the existing --user-agent flag
+      // (embedder_support::kUserAgent). Chromium's user-agent plumbing
+      // then handles both HTTP User-Agent header generation and the JS
+      // navigator.userAgent value, and propagates to child processes via
+      // the kCommonSwitchNames copy in AppendExtraCommandLineSwitches.
+      if (fp->IsLoaded()) {
+        const std::string ua = fp->UserAgent();
+        if (!ua.empty() &&
+            !cmd_line->HasSwitch(embedder_support::kUserAgent)) {
+          cmd_line->AppendSwitchASCII(embedder_support::kUserAgent, ua);
+        }
+      }
     }
   }
 
