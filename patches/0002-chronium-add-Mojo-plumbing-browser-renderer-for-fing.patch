 #include "chrome/common/open_search_description_document_handler.mojom.h"
 #include "chrome/common/webui_url_constants.h"
 #include "chrome/renderer/actor/journal.h"
@@ -283,6 +284,31 @@ void ChromeRenderFrameObserver::DidFinishLoad() {
 }
 
 void ChromeRenderFrameObserver::DidCreateNewDocument() {
+  // Chronium: fetch per-frame fingerprint config from the browser. Later
+  // fingerprint patches (canvas noise, WebGL spoof, ...) will read from the
+  // per-frame store this populates. For now we just log seed[0] to prove
+  // the wire-up: browser singleton -> Mojo -> renderer.
+  if (render_frame() && render_frame()->IsMainFrame()) {
+    mojo::Remote<chrome::mojom::FingerprintConfigProvider> fp_provider;
+    render_frame()->GetBrowserInterfaceBroker().GetInterface(
+        fp_provider.BindNewPipeAndPassReceiver());
+    auto* raw = fp_provider.get();
+    raw->GetConfig(base::BindOnce(
+        [](mojo::Remote<chrome::mojom::FingerprintConfigProvider>,
+           chrome::mojom::FingerprintConfigPtr config) {
+          if (config && config->seed.size() == 32) {
+            LOG(INFO) << "[chronium-renderer] fp config received, seed[0..3]="
+                      << static_cast<int>(config->seed[0]) << ","
+                      << static_cast<int>(config->seed[1]) << ","
+                      << static_cast<int>(config->seed[2]) << ","
+                      << static_cast<int>(config->seed[3]);
+          } else {
+            LOG(INFO) << "[chronium-renderer] fp config received (empty)";
+          }
+        },
+        std::move(fp_provider)));
+  }
+
 #if BUILDFLAG(ENABLE_OFFLINE_PAGES)
   DCHECK(render_frame());
   if (!render_frame()->IsMainFrame())
