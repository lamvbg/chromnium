+++ b/chrome/common/fingerprint.mojom
@@ -0,0 +1,24 @@
+// Copyright 2026 The Chronium Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license.
+
+// Chronium: per-frame fingerprint configuration delivered from the browser
+// process (which loaded the JSON at startup, see patch 0001) to each
+// renderer frame. All anti-detect Blink patches will read from a per-frame
+// store populated via this interface.
+
+module chrome.mojom;
+
+struct FingerprintConfig {
+  // 32-byte seed for deterministic noise generators. All-zero when no
+  // fingerprint profile is active on the browser side.
+  array<uint8> seed;
+};
+
+// Renderer-to-browser interface. The browser exposes one instance per
+// RenderFrameHost; the renderer obtains it through the
+// BrowserInterfaceBroker associated with the RenderFrame.
+interface FingerprintConfigProvider {
+  // Returns the active fingerprint config for this frame, or an empty
+  // config (all-zero seed) when no profile is loaded.
+  GetConfig() => (FingerprintConfig config);
+};
